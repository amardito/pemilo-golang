# ── Local development ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://pemilo:pemilo_secret@localhost:5432/pemilo?sslmode=disable
JWT_SECRET=change-me-to-a-strong-secret-key
JWT_EXPIRY=24h
PORT=8080
CORS_ORIGINS=http://localhost:3000
CLIENT_ORIGINS=http://localhost:3000
IPAYMU_VA=your-va-number
IPAYMU_API_KEY=your-api-key
IPAYMU_BASE_URL=https://sandbox.ipaymu.com/api/v2
IPAYMU_CALLBACK_URL=http://localhost:8080/api/payments/ipaymu/webhook

# ── Railway deployment ─────────────────────────────────────────────────────────
# DATABASE_URL  → set automatically by Railway Postgres plugin
# PORT          → set automatically by Railway (do not override)
# CORS_ORIGINS  → your deployed Next.js public URL, e.g. https://pemilo.up.railway.app
# CLIENT_ORIGINS → same as CORS_ORIGINS
# IPAYMU_CALLBACK_URL → https://<your-go-service>.up.railway.app/api/payments/ipaymu/webhook
